# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging artifacts
build/
dist/
site/
*.egg-info/
.eggs/
*.whl
pip-wheel-metadata/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.hypothesis/

# Type checker / linter caches
.mypy_cache/
.ruff_cache/
.pyre/
.cache/

# Jupyter and notebook checkpoints
.ipynb_checkpoints/

# Python tooling
.tox/
.nox/
.python-version/

# Environment and local secrets
.env
.env.*
*.env

# Streamlit local secrets and runtime caches
.streamlit/secrets.toml
.streamlit/cache/

# IDE/editor settings
# Keep shareable VS Code workspace config while ignoring local machine state.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# OS-generated files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.temp
